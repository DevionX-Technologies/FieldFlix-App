# This `.xcode.env` file is versioned and is used to source the environment
# used when running script phases inside Xcode.
# To customize your local environment, you can create an `.xcode.env.local`
# file that is not versioned.

# NODE_BINARY: path to node for Xcode script phases (PATH is often minimal on CI/EAS).
# If NODE_BINARY from .xcode.env.local points at a missing file, ignore it - see Expo EAS #1264.
if [ -n "$NODE_BINARY" ] && [ ! -x "$NODE_BINARY" ]; then
  unset NODE_BINARY
fi
if [ -z "$NODE_BINARY" ]; then
  _n=$(command -v node 2>/dev/null)
  if [ -n "$_n" ] && [ -x "$_n" ]; then
    export NODE_BINARY="$_n"
  elif [ -x "/usr/local/bin/node" ]; then
    export NODE_BINARY="/usr/local/bin/node"
  elif [ -x "/opt/homebrew/bin/node" ]; then
    export NODE_BINARY="/opt/homebrew/bin/node"
  else
    for _ver in $(ls -1 "/Users/expo/.nvm/versions/node" 2>/dev/null | sort -V); do
      _p="/Users/expo/.nvm/versions/node/${_ver}/bin/node"
      if [ -x "$_p" ]; then export NODE_BINARY="$_p"; break; fi
    done
  fi
  unset _n _ver _p 2>/dev/null || true
fi
